# Supabase — server-side only, never expose to client
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# football-data.org free tier token
FOOTBALL_DATA_TOKEN=your-token-here

# Shared secret for Vercel Cron routes (also set in Vercel env)
CRON_SECRET=generate-a-random-string

# Shared passcode for the league — five friends only
LEAGUE_PASSCODE=your-secret-passcode

# iron-session encryption password — min 32 chars
SESSION_PASSWORD=generate-at-least-32-random-chars-here

# Giphy API key for the comments-feed GIF picker (optional — the GIF button
# hides itself when unset). Free key: https://developers.giphy.com
GIPHY_API_KEY=your-giphy-key
