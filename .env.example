# Supabase — server-side only, never expose to client
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# football-data.org free tier token — schedule, status, final score (NOT goals/cards/lineups)
FOOTBALL_DATA_TOKEN=your-token-here

# API-Football (api-sports.io) key — goals/cards/lineups for player props, which the
# football-data free tier omits. Direct access key from https://dashboard.api-football.com
# (NOT a RapidAPI key). Needs the Pro plan ($19/mo): the free plan only exposes seasons
# 2022–2024, not WC2026. Optional WC overrides if the defaults drift (league 1 / 2026).
API_FOOTBALL_KEY=your-api-football-key
# API_FOOTBALL_WC_LEAGUE_ID=1
# API_FOOTBALL_WC_SEASON=2026

# Shared secret for Vercel Cron routes (also set in Vercel env)
CRON_SECRET=generate-a-random-string

# Shared passcode for the league — five friends only
LEAGUE_PASSCODE=your-secret-passcode

# iron-session encryption password — min 32 chars
SESSION_PASSWORD=generate-at-least-32-random-chars-here

# Giphy API key for the comments-feed GIF picker (optional — the GIF button
# hides itself when unset). Free key: https://developers.giphy.com
GIPHY_API_KEY=your-giphy-key
